# D&D Session Assistant — backend environment.
# Copy to `.env` (gitignored) and fill in real values. NEVER commit a real .env.

# --- CORS ---
# Comma-separated origins allowed to call the API.
ALLOWED_ORIGINS=http://localhost:5173

# --- STT provider keys (long-lived; server-side only, NEVER returned to client) ---
SONIOX_API_KEY=
DEEPGRAM_API_KEY=

# --- Token behaviour ---
# Set to 1 to return a dummy token without needing real provider keys (local dev).
DEV_FAKE_TOKEN=1
# Requested lifetime (seconds) for minted short-lived tokens.
STT_TOKEN_TTL_SECONDS=300

# --- Storage ---
# If a GCP project is set (and/or GOOGLE_APPLICATION_CREDENTIALS points at a key
# file), transcripts go to Firestore. Otherwise they fall back to local JSONL.
GCP_PROJECT=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Directory for the local JSONL fallback store.
LOCAL_STORAGE_DIR=./data

# --- Auth (Firebase) ---
# Comma-separated Google account emails allowed to sign in.
# An empty list means nobody is allowed (fail-closed) — always set this in prod.
ALLOWED_EMAILS=
# Set to 1 to bypass Firebase auth entirely for LOCAL DEV (never in prod).
DEV_AUTH_BYPASS=1

# --- Cost guard ---
# Max transcript segments accepted per request (requests over this limit get 422).
MAX_TRANSCRIPT_SEGMENTS=1000
