# ---- Frontend (Vite) ----
# Base URL of the backend API. Leave blank in local dev to use the Vite proxy.
VITE_API_BASE=

# Which STT provider the client should request a token for: "soniox" | "deepgram"
VITE_STT_PROVIDER=soniox

# LOCAL DEV ONLY: set to 1 to skip the Google sign-in gate. Also auto-skipped when
# VITE_FIREBASE_API_KEY below is blank, so `npm run dev` works zero-config. Pair with
# backend DEV_AUTH_BYPASS=1. Never set in a production build.
VITE_AUTH_BYPASS=

# Enable verbose structured debug logging in the browser console.
# Logs include raw STT segments, keyterm lists, and scanner candidate/miss detail.
# OFF by default and should never be set to "true" in production builds.
# Privacy: debug logs contain real table-audio transcript text.
# Runtime escape hatch (no rebuild needed): window.__DND_DEBUG = true in DevTools.
VITE_DEBUG=false

# Firebase web config (non-secret; from Firebase console > Project settings > Your apps).
# These values are safe to commit in .env.example — they identify the project but do not
# grant access on their own. The real values belong in a .env file (never committed).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=dnd-session-assistant-52633
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=

# ---- Backend (FastAPI) ----  [keep the real values in backend/.env, never commit]
SONIOX_API_KEY=
DEEPGRAM_API_KEY=

# Comma-separated list of origins allowed to call the API (CORS).
ALLOWED_ORIGINS=http://localhost:5173

# GCP / Firestore (used in cloud deploy; local dev can run without storage)
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DATABASE=(default)
